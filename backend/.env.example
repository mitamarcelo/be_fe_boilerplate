PORT=3000
NODE_ENV=development
JWT_SECRET=change-me
JWT_EXPIRES_IN=1h
APP_NAME=boilerplate
DB_HOST=localhost
DB_PORT=3306
DB_NAME="${APP_NAME}_db"
DB_USER="${APP_NAME}_user"
DB_PASSWORD=change-me
DB_SSL=false

# Do not change these. They are used by prisma and build the urls with the other DB_* variables.
DATABASE_URL="mysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}"
PRISMA_SHADOW_DATABASE_URL="mysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/prisma_shadow_${DB_NAME}"